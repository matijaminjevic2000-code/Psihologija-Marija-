---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import marijaPhoto from '../assets/marija-kristic.jpg';
---

<BaseLayout
  title="Marija Krstić — REBT psihoterapeut u edukaciji | Forma Uma"
  description="Marija Krstić, REBT psihoterapeut u edukaciji. Psihoterapija u Beogradu i online, na srpskom, engleskom i nemačkom jeziku."
>

  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Marija Krstić",
    "jobTitle": "REBT psihoterapeut u edukaciji",
    "email": "psihoterapijasaMK@gmail.com",
    "url": "https://formauma.rs/o-nama",
    "knowsLanguage": ["sr", "en", "de"],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Beograd",
      "addressCountry": "RS"
    },
    "hasOccupation": {
      "@type": "Occupation",
      "name": "REBT psihoterapeut u edukaciji",
      "occupationLocation": {
        "@type": "City",
        "name": "Beograd"
      }
    },
    "alumniOf": {
      "@type": "EducationalOrganization",
      "name": "Filozofski fakultet, Univerzitet u Beogradu"
    },
    "worksFor": {
      "@type": "MedicalBusiness",
      "name": "Forma Uma",
      "url": "https://formauma.rs"
    }
  })} />

  <Nav />

  <main>

    <!-- ═══ HERO ══════════════════════════════════════════════════════════ -->
    <section class="therapist-hero">
      <div class="container therapist-hero-inner">
        <Image
          src={marijaPhoto}
          alt="Marija Krstić, REBT psihoterapeut u edukaciji"
          width={240}
          class="therapist-photo"
        />
        <div class="therapist-intro">
          <p class="eyebrow">O nama</p>
          <h1>Marija Krstić</h1>
          <p class="therapist-title">REBT psihoterapeut u edukaciji</p>
          <p class="therapist-meta">Beograd · online · srpski, engleski, nemački</p>
        </div>
      </div>
    </section>

    <!-- ═══ O MENI ════════════════════════════════════════════════════════ -->
    <section class="about-section">
      <div class="container about-inner">
        <div class="about-label">
          <p class="eyebrow">O meni</p>
        </div>
        <div class="about-text">
          <p>[Marija — ovde ide tvoj lični tekst o sebi i pristupu radu]</p>
        </div>
      </div>
    </section>

    <!-- ═══ OBRAZOVANJE I PRAVCI ══════════════════════════════════════════ -->
    <section class="education">
      <div class="container">
        <div class="section-header">
          <p class="eyebrow">Stručnost</p>
          <h2>Obrazovanje i edukacija</h2>
        </div>

        <div class="education-grid">

          <div class="education-col">
            <h3>Obrazovanje i edukacija</h3>
            <ul class="edu-list">
              <li>
                <span class="dir-dot"></span>
                <div>
                  <strong>Filozofski fakultet</strong>
                  <p>Univerzitet u Beogradu</p>
                </div>
              </li>
              <li>
                <span class="dir-dot"></span>
                <div>
                  <strong>Akreditovana REBT edukacija</strong>
                </div>
              </li>
              <li>
                <span class="dir-dot"></span>
                <div>
                  <strong>REBT psihoterapeut u edukaciji</strong>
                  <p>Zvanje u toku akreditovane edukacije</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="education-col">
            <h3>Terapijski pravci</h3>
            <ul class="directions-list">
              <li>
                <span class="dir-dot"></span>
                <div>
                  <strong>[Marija — ovde ide naziv pravca]</strong>
                  <p>[Kratko objašnjenje]</p>
                </div>
              </li>
              <li>
                <span class="dir-dot"></span>
                <div>
                  <strong>[Drugi pravac]</strong>
                  <p>[Kratko objašnjenje]</p>
                </div>
              </li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══ CITAT ══════════════════════════════════════════════════════════ -->
    <section class="quote-strip">
      <div class="container quote-inner">
        <blockquote>
          <p>„[Marija — ni ne znaš da imaš problem]"</p>
          <footer>
            <cite>— Marija Krstić, REBT psihoterapeut u edukaciji</cite>
          </footer>
        </blockquote>
      </div>
    </section>

    <!-- ═══ CTA TRAKA ═════════════════════════════════════════════════════ -->
    <section class="cta-strip">
      <div class="container cta-inner">
        <h2>Zanimljivo vam zvuči ovaj pristup?</h2>
        <a href="/kontakt" class="btn btn-primary btn-lg">Zakažite besplatnu konsultaciju</a>
      </div>
    </section>

  </main>

  <Footer />

</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    max-width: none;
  }

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .therapist-hero {
    padding-top: var(--space-20);
    padding-bottom: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .therapist-hero-inner {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: var(--space-12);
    align-items: center;
    max-width: var(--container-lg);
  }

  @media (max-width: 767px) {
    .therapist-hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  .therapist-photo {
    width: 240px;
    height: auto;
    border-radius: var(--radius-lg);
    display: block;
    flex-shrink: 0;
    object-fit: cover;
  }

  @media (max-width: 767px) {
    .therapist-photo {
      width: 100%;
      max-width: 280px;
    }
  }

  .therapist-intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .therapist-intro h1 {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .therapist-title {
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-text);
    max-width: none;
  }

  .therapist-meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    max-width: none;
  }

  /* ── About ────────────────────────────────────────────────────────────── */
  .about-section {
    padding-block: var(--space-24);
    border-bottom: 1px solid var(--color-border);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: var(--space-16);
    max-width: var(--container-lg);
  }

  @media (max-width: 767px) {
    .about-inner { grid-template-columns: 1fr; gap: var(--space-6); }
  }

  .about-label {
    padding-top: 4px;
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .about-text p {
    font-size: var(--text-md);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    max-width: 60ch;
  }

  /* ── Education ────────────────────────────────────────────────────────── */
  .education {
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-24);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    font-size: var(--text-3xl);
    font-weight: 600;
  }

  .education-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
  }

  @media (max-width: 767px) {
    .education-grid { grid-template-columns: 1fr; gap: var(--space-12); }
  }

  .education-col h3 {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .edu-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .edu-list li {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .edu-list strong {
    display: block;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .edu-list p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    max-width: none;
  }

  .directions-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .directions-list li {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .dir-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 7px;
  }

  .directions-list strong {
    display: block;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .directions-list p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    max-width: none;
  }

  /* ── Quote ────────────────────────────────────────────────────────────── */
  .quote-strip {
    background-color: var(--color-accent);
    padding-block: var(--space-20);
  }

  .quote-inner {
    max-width: var(--container-md);
  }

  .quote-strip blockquote p {
    font-family: var(--font-display);
    font-size: clamp(var(--text-xl), 2.5vw, var(--text-2xl));
    font-weight: 400;
    font-style: italic;
    line-height: var(--leading-snug);
    color: var(--color-white);
    max-width: none;
  }

  .quote-strip blockquote footer {
    margin-top: var(--space-6);
  }

  .quote-strip cite {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: normal;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 0.03em;
  }

  /* ── CTA strip ────────────────────────────────────────────────────────── */
  .cta-strip {
    padding-block: var(--space-24);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-8);
  }

  .cta-inner h2 {
    font-size: clamp(var(--text-2xl), 3.5vw, var(--text-3xl));
    font-weight: 600;
    line-height: var(--leading-snug);
  }

  .btn-lg {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-sm);
  }

  @media (max-width: 767px) {
    .therapist-intro h1 { font-size: var(--text-2xl); }
    .therapist-tagline { font-size: var(--text-base); }
    .about-text p { font-size: var(--text-base); }
    .section-header { margin-bottom: var(--space-8); }
    .section-header h2 { font-size: var(--text-2xl); }
    .edu-list li { gap: var(--space-3); }
    .cta-inner h2 { font-size: var(--text-2xl); }
    .cta-inner .btn { width: 100%; max-width: 320px; justify-content: center; }
  }
</style>
