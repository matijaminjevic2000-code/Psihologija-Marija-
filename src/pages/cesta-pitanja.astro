---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Da li je prva konsultacija besplatna i koliko traje?",
      acceptedAnswer: { "@type": "Answer", text: "Da, prva konsultacija je besplatna i služi za upoznavanje. Ja se upoznajem sa vama i onim što vas dovodi, a vi sa mnom i mojim načinom rada. Prosečno traje 30–45 minuta." }
    },
    {
      "@type": "Question",
      name: "Šta se dešava na prvoj konsultaciji?",
      acceptedAnswer: { "@type": "Answer", text: "Konsultacija nije terapijska seansa, već prilika da se pre rada upoznamo. Stičemo utisak jedno o drugom i zajedno procenjujemo da li su moj pravac i način rada pravi izbor za vas. Meni daje priliku da se pripremim za prvu seansu, kako ne bismo gubili vreme. Na samom problemu još ne radimo — to počinje od prve seanse." }
    },
    {
      "@type": "Question",
      name: "Kako se zakazuje termin?",
      acceptedAnswer: { "@type": "Answer", text: "Termin možete zakazati putem email adrese, kontakt forme na sajtu ili poruke na broj telefona. Na pozive ne odgovaram pre dogovorenog termina." }
    },
    {
      "@type": "Question",
      name: "Treba li nešto da pripremim pre prvog susreta?",
      acceptedAnswer: { "@type": "Answer", text: "Nije potrebna nikakva posebna priprema — dovoljno je da imate problem ili temu koju želite da rešite. Sve ostalo prolazimo zajedno tokom konsultacije." }
    },
    {
      "@type": "Question",
      name: "Koliko traje jedna seansa?",
      acceptedAnswer: { "@type": "Answer", text: "Prosečno između 55 i 70 minuta." }
    },
    {
      "@type": "Question",
      name: "Koliko često se dolazi na terapiju?",
      acceptedAnswer: { "@type": "Answer", text: "Najčešće jednom nedeljno, mada se tempo prilagođava od slučaja do slučaja." }
    },
    {
      "@type": "Question",
      name: "Kolika je cena seanse?",
      acceptedAnswer: { "@type": "Answer", text: "Cenu dogovaramo na konsultaciji i u skladu je sa uobičajenim cenama za psihoterapijski rad." }
    },
    {
      "@type": "Question",
      name: "Koji su načini plaćanja?",
      acceptedAnswer: { "@type": "Answer", text: "Plaćanje je moguće gotovinom, karticom ili kriptovalutama." }
    },
    {
      "@type": "Question",
      name: "Šta ako moram da otkažem termin?",
      acceptedAnswer: { "@type": "Answer", text: "Uvek se trudim da imam razumevanja za otkazane termine. Molim vas da otkazivanje najavite na vreme kad god je to moguće." }
    },
    {
      "@type": "Question",
      name: "Da li radite uživo ili online?",
      acceptedAnswer: { "@type": "Answer", text: "Radim i uživo i online. Oba oblika su efikasna; u praksi se pokazalo da mnogi ljudi nešto lakše reaguju na rad uživo, ali online je potpuno ravnopravan izbor kada vam tako više odgovara." }
    },
    {
      "@type": "Question",
      name: "Kako izgleda online seansa?",
      acceptedAnswer: { "@type": "Answer", text: "Online seanse održavam preko Microsoft Teams-a, Google Meet-a ili WhatsApp video poziva — kako vam je najlakše." }
    },
    {
      "@type": "Question",
      name: "Na kojim jezicima se može raditi?",
      acceptedAnswer: { "@type": "Answer", text: "Terapiju vodim tečno na srpskom i engleskom jeziku. Mogu i na nemačkom, uz povremenu pomoć engleskog." }
    },
    {
      "@type": "Question",
      name: "Sa kim radite?",
      acceptedAnswer: { "@type": "Answer", text: "Trenutno radim individualno, sa punoletnim osobama. Parove i osobe mlađe od 18 godina ne primam, osim u posebnim okolnostima." }
    },
    {
      "@type": "Question",
      name: "Sa kojim temama se ljudi najčešće javljaju?",
      acceptedAnswer: { "@type": "Answer", text: "Najčešće radimo na: anksioznosti, stresu, osećaju niže vrednosti i manjku samopouzdanja, problemima na poslu i sa autoritetom, problemima u partnerskim odnosima, agresiji, fobijama i strahovima, te opsesivno-kompulsivnom poremećaju (OKP)." }
    },
    {
      "@type": "Question",
      name: "Šta je REBT?",
      acceptedAnswer: { "@type": "Answer", text: "REBT (Racionalno-emotivno-bihejvioralna terapija) praktičan je pravac u psihoterapiji koji vas uči da način na koji tumačite događaje — a ne sami događaji — oblikuje vaše emocije. Cilj je prepoznati iracionalna uverenja i zameniti ih racionalnim, radi trajnije emocionalne stabilnosti. Fokus na sadašnjosti: iako se uzimaju u obzir iskustva iz prošlosti, REBT je najviše usmeren na rešavanje vaših trenutnih problema. Preuzimanje odgovornosti: radi se na onome na šta realno možete da utičete — sopstvenim mislima, reakcijama i ponašanju. Akcija i zadaci: zajedno radimo na vežbama koje primenjujete između seansi." }
    },
    {
      "@type": "Question",
      name: "Koliko dugo traje terapija?",
      acceptedAnswer: { "@type": "Answer", text: "Trajanje je individualno i zavisi od toga sa čime se radi i od vaših ciljeva. Neki ljudi osete pomak već nakon nekoliko nedelja ili meseci, dok je nekima potrebno duže. Tempo i trajanje procenjujemo zajedno tokom rada." }
    },
    {
      "@type": "Question",
      name: "Da li je online terapija jednako efikasna kao uživo?",
      acceptedAnswer: { "@type": "Answer", text: "Online psihoterapija je efikasan oblik rada. U mom iskustvu, neki ljudi se nešto lakše opuste uživo, ali mnogi odlično napreduju i online — birate ono što vama prija." }
    },
    {
      "@type": "Question",
      name: "Nisam siguran/na da li mi uopšte treba terapija.",
      acceptedAnswer: { "@type": "Answer", text: "Sasvim je u redu ne biti siguran. Upravo zato postoji besplatna konsultacija — bez obaveze, da zajedno vidimo da li bi vam rad pomogao. Ako zaključimo da nije pravi trenutak ili pravi pristup za vas, i to je sasvim u redu." }
    },
    {
      "@type": "Question",
      name: "Da li je sve poverljivo?",
      acceptedAnswer: { "@type": "Answer", text: "Sve o čemu razgovaramo ostaje između nas. Psihoterapija je sigurno mesto gde možete reći šta stvarno mislite i osećate, bez straha od osude." }
    },
    {
      "@type": "Question",
      name: "Da li psihoterapeut prepisuje lekove?",
      acceptedAnswer: { "@type": "Answer", text: "Psihoterapeut ne prepisuje lekove — to je u nadležnosti psihijatra. U terapiji na promeni radimo kroz razgovor i rad na mislima i ponašanju. U mnogim slučajevima napredak je moguć i bez lekova; kada je psihijatrijska podrška potrebna, može se sprovoditi paralelno." }
    }
  ]
};
---

<BaseLayout
  title="Česta pitanja o psihoterapiji — Forma Uma"
  description="Odgovori na najčešća pitanja o psihoterapijskim sesijama, prvoj konsultaciji, online radu i načinu zakazivanja u praksi Forma Uma."
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Nav />

  <main id="main-content">

    <!-- ═══ HERO ══════════════════════════════════════════════════════════ -->
    <section class="page-hero">
      <div class="container page-hero-inner">
        <p class="eyebrow">Česta pitanja</p>
        <h1>Šta vas zanima pre prvog koraka?</h1>
        <p class="page-hero-sub">
          Ovde smo sakupili pitanja koja ljudi najčešće postavljaju.
          Ako ne nađete odgovor koji tražite, slobodno nas kontaktirajte.
        </p>
      </div>
    </section>

    <!-- ═══ FAQ ═══════════════════════════════════════════════════════════ -->
    <section class="faq">
      <div class="container">

        <!-- Konsultacija i zakazivanje -->
        <div class="faq-group">
          <h2 class="faq-group-heading">Konsultacija i zakazivanje</h2>
          <dl class="faq-list">

            <div class="faq-item">
              <dt>Da li je prva konsultacija besplatna i koliko traje?</dt>
              <dd>
                Da, prva konsultacija je besplatna i služi za upoznavanje.
                Ja se upoznajem sa vama i onim što vas dovodi, a vi sa mnom i mojim
                načinom rada. Prosečno traje 30–45 minuta.
              </dd>
            </div>

            <div class="faq-item">
              <dt>Šta se dešava na prvoj konsultaciji?</dt>
              <dd>
                Konsultacija nije terapijska seansa, već prilika da se pre rada
                upoznamo. Stičemo utisak jedno o drugom i zajedno procenjujemo da li
                su moj pravac i način rada pravi izbor za vas. Meni daje priliku da
                se pripremim za prvu seansu, kako ne bismo gubili vreme. Na samom
                problemu još ne radimo — to počinje od prve seanse.
              </dd>
            </div>

            <div class="faq-item">
              <dt>Kako se zakazuje termin?</dt>
              <dd>
                Termin možete zakazati putem email adrese, kontakt forme na sajtu
                ili poruke na broj telefona. Na pozive ne odgovaram pre dogovorenog
                termina.
              </dd>
            </div>

            <div class="faq-item">
              <dt>Treba li nešto da pripremim pre prvog susreta?</dt>
              <dd>
                Nije potrebna nikakva posebna priprema — dovoljno je da imate problem
                ili temu koju želite da rešite. Sve ostalo prolazimo zajedno tokom
                konsultacije.
              </dd>
            </div>

          </dl>
        </div>

        <!-- Seanse i cena -->
        <div class="faq-group">
          <h2 class="faq-group-heading">Seanse i cena</h2>
          <dl class="faq-list">

            <div class="faq-item">
              <dt>Koliko traje jedna seansa?</dt>
              <dd>Prosečno između 55 i 70 minuta.</dd>
            </div>

            <div class="faq-item">
              <dt>Koliko često se dolazi na terapiju?</dt>
              <dd>Najčešće jednom nedeljno, mada se tempo prilagođava od slučaja do slučaja.</dd>
            </div>

            <div class="faq-item">
              <dt>Kolika je cena seanse?</dt>
              <dd>
                Cenu dogovaramo na konsultaciji i u skladu je sa uobičajenim cenama
                za psihoterapijski rad.
              </dd>
            </div>

            <div class="faq-item">
              <dt>Koji su načini plaćanja?</dt>
              <dd>Plaćanje je moguće gotovinom, karticom ili kriptovalutama.</dd>
            </div>

            <div class="faq-item">
              <dt>Šta ako moram da otkažem termin?</dt>
              <dd>
                Uvek se trudim da imam razumevanja za otkazane termine. Molim vas da
                otkazivanje najavite na vreme kad god je to moguće.
              </dd>
            </div>

          </dl>
        </div>

        <!-- Format i jezik rada -->
        <div class="faq-group">
          <h2 class="faq-group-heading">Format i jezik rada</h2>
          <dl class="faq-list">

            <div class="faq-item">
              <dt>Da li radite uživo ili online?</dt>
              <dd>
                Radim i uživo i online. Oba oblika su efikasna; u praksi se pokazalo
                da mnogi ljudi nešto lakše reaguju na rad uživo, ali online je potpuno
                ravnopravan izbor kada vam tako više odgovara.
              </dd>
            </div>

            <div class="faq-item">
              <dt>Kako izgleda online seansa?</dt>
              <dd>
                Online seanse održavam preko Microsoft Teams-a, Google Meet-a ili
                WhatsApp video poziva — kako vam je najlakše.
              </dd>
            </div>

            <div class="faq-item">
              <dt>Na kojim jezicima se može raditi?</dt>
              <dd>
                Terapiju vodim tečno na srpskom i engleskom jeziku. Mogu i na
                nemačkom, uz povremenu pomoć engleskog.
              </dd>
            </div>

            <div class="faq-item">
              <dt>Sa kim radite?</dt>
              <dd>
                Trenutno radim individualno, sa punoletnim osobama. Parove i osobe
                mlađe od 18 godina ne primam, osim u posebnim okolnostima.
              </dd>
            </div>

          </dl>
        </div>

        <!-- O terapiji i pristupu -->
        <div class="faq-group">
          <h2 class="faq-group-heading">O terapiji i pristupu</h2>
          <dl class="faq-list">

            <div class="faq-item">
              <dt>Sa kojim temama se ljudi najčešće javljaju?</dt>
              <dd>
                Najčešće radimo na: anksioznosti, stresu, osećaju niže vrednosti i
                manjku samopouzdanja, problemima na poslu i sa autoritetom, problemima
                u partnerskim odnosima, agresiji, fobijama i strahovima, te
                opsesivno-kompulsivnom poremećaju (OKP).
              </dd>
            </div>

            <div class="faq-item">
              <dt>Šta je REBT?</dt>
              <dd>
                REBT (Racionalno-emotivno-bihejvioralna terapija) praktičan je
                pravac u psihoterapiji koji vas uči da način na koji tumačite
                događaje — a ne sami događaji — oblikuje vaše emocije. Cilj je
                prepoznati iracionalna uverenja i zameniti ih racionalnim, radi
                trajnije emocionalne stabilnosti.
                <ul>
                  <li>
                    <strong>Fokus na sadašnjosti:</strong> iako se uzimaju u obzir
                    iskustva iz prošlosti, REBT je najviše usmeren na rešavanje vaših
                    trenutnih problema.
                  </li>
                  <li>
                    <strong>Preuzimanje odgovornosti:</strong> radi se na onome na šta
                    realno možete da utičete — sopstvenim mislima, reakcijama i
                    ponašanju.
                  </li>
                  <li>
                    <strong>Akcija i zadaci:</strong> zajedno radimo na vežbama koje
                    primenjujete između seansi.
                  </li>
                </ul>
              </dd>
            </div>

            <div class="faq-item">
              <dt>Koliko dugo traje terapija?</dt>
              <dd>
                Trajanje je individualno i zavisi od toga sa čime se radi i od vaših
                ciljeva. Neki ljudi osete pomak već nakon nekoliko nedelja ili meseci,
                dok je nekima potrebno duže. Tempo i trajanje procenjujemo zajedno
                tokom rada.
              </dd>
            </div>

            <div class="faq-item">
              <dt>Da li je online terapija jednako efikasna kao uživo?</dt>
              <dd>
                Online psihoterapija je efikasan oblik rada. U mom iskustvu, neki
                ljudi se nešto lakše opuste uživo, ali mnogi odlično napreduju i
                online — birate ono što vama prija.
              </dd>
            </div>

            <div class="faq-item">
              <dt>Nisam siguran/na da li mi uopšte treba terapija.</dt>
              <dd>
                Sasvim je u redu ne biti siguran. Upravo zato postoji besplatna
                konsultacija — bez obaveze, da zajedno vidimo da li bi vam rad
                pomogao. Ako zaključimo da nije pravi trenutak ili pravi pristup
                za vas, i to je sasvim u redu.
              </dd>
            </div>

            <div class="faq-item">
              <dt>Da li je sve poverljivo?</dt>
              <dd>
                Sve o čemu razgovaramo ostaje između nas. Psihoterapija je sigurno
                mesto gde možete reći šta stvarno mislite i osećate, bez straha
                od osude.
              </dd>
            </div>

            <div class="faq-item">
              <dt>Da li psihoterapeut prepisuje lekove?</dt>
              <dd>
                Psihoterapeut ne prepisuje lekove — to je u nadležnosti psihijatra.
                U terapiji na promeni radimo kroz razgovor i rad na mislima i
                ponašanju. U mnogim slučajevima napredak je moguć i bez lekova;
                kada je psihijatrijska podrška potrebna, može se sprovoditi
                paralelno.
              </dd>
            </div>

          </dl>
        </div>

      </div>
    </section>

    <!-- ═══ CTA TRAKA ═════════════════════════════════════════════════════ -->
    <section class="cta-strip">
      <div class="container cta-inner">
        <h2>Imate još pitanja?</h2>
        <a href="/kontakt" class="btn btn-primary btn-lg" data-booking-trigger>
          Zakažite besplatnu konsultaciju
        </a>
      </div>
    </section>

  </main>

  <Footer />

</BaseLayout>

<style>
  .eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    max-width: none;
  }

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .page-hero {
    padding-top: var(--space-20);
    padding-bottom: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .page-hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: var(--container-md);
  }

  .page-hero h1 {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .page-hero-sub {
    font-size: var(--text-md);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-width: 56ch;
  }

  /* ── FAQ ──────────────────────────────────────────────────────────────── */
  .faq {
    padding-block: var(--space-20);
  }

  .faq-group {
    max-width: var(--container-md);
    margin-bottom: var(--space-16);
  }

  .faq-group:last-child {
    margin-bottom: 0;
  }

  .faq-group-heading {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-6);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--color-border);
  }

  .faq-item {
    padding-block: var(--space-8);
    border-bottom: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  @media (max-width: 767px) {
    .faq-item {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }

  .faq-item dt {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: var(--leading-snug);
    color: var(--color-text);
  }

  .faq-item dd {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    max-width: 52ch;
  }

  .faq-item dd ul {
    list-style: disc;
    padding-left: var(--space-5);
    margin-top: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .faq-item dd li {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
  }

  /* ── CTA strip ────────────────────────────────────────────────────────── */
  .cta-strip {
    padding-block: var(--space-24);
    border-top: 1px solid var(--color-border);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-8);
  }

  .cta-inner h2 {
    font-size: clamp(var(--text-2xl), 3.5vw, var(--text-3xl));
    font-weight: 600;
    line-height: var(--leading-snug);
  }

  .btn-lg {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-sm);
  }

  @media (max-width: 767px) {
    .page-hero h1 { font-size: var(--text-2xl); }
    .page-hero-sub { font-size: var(--text-base); }
    .faq-item dd { max-width: 100%; }
    .cta-inner h2 { font-size: var(--text-2xl); }
    .cta-inner .btn { width: 100%; max-width: 320px; justify-content: center; }
  }
</style>
