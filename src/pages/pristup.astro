---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Pristup — Forma Uma"
  description="Kako izgleda rad sa nama — koraci, teme i format psihoterapijskih seansi."
>

  <Nav />

  <main id="main-content">

    <!-- ═══ HERO ══════════════════════════════════════════════════════════ -->
    <section class="page-hero">
      <div class="container page-hero-inner">
        <p class="eyebrow">Pristup</p>
        <h1>Kako izgleda rad sa nama</h1>
        <p class="page-hero-sub">
          Svaki proces je drugačiji — ali postoje koraci koji važe za sve.
          Ovde možete videti šta da očekujete pre prvog susreta, tokom njega
          i u nastavku rada.
        </p>
      </div>
    </section>

    <!-- ═══ TRI KORAKA ═══════════════════════════════════════════════════ -->
    <section class="steps">
      <div class="container">

        <div class="section-header">
          <p class="eyebrow">Proces</p>
          <h2>Kako teče prvi korak</h2>
        </div>

        <ol class="steps-list">

          <li class="step">
            <div class="step-number">01</div>
            <div class="step-body">
              <h3>Besplatna konsultacija</h3>
              <p>
                Počinjemo kratkim razgovorom od petnaestak minuta — telefonom
                ili video pozivom. Cilj nije dijagnoza ni procena, već da
                proverite da li vam odgovara način na koji radimo i da dobijete
                odgovore na praktična pitanja pre nego što se odlučite.
              </p>
            </div>
          </li>

          <li class="step">
            <div class="step-number">02</div>
            <div class="step-body">
              <h3>Prvi susret</h3>
              <p>
                Prva seansa traje oko pedeset minuta. Nema testova ni formulara
                — samo razgovor. Pričate o tome šta vas dovodi, šta ste već
                probali i šta biste hteli da bude drugačije. Terapeut sluša,
                postavlja pitanja i zajedno definišete smer rada.
              </p>
            </div>
          </li>

          <li class="step">
            <div class="step-number">03</div>
            <div class="step-body">
              <h3>Redovan rad</h3>
              <p>
                Seanse se najčešće odvijaju jednom nedeljno, u dogovorenom
                terminu. Tempo i učestalost prilagođavamo vašim potrebama i
                životnim okolnostima. Napredak se ne meri brojem seansi —
                meri se time kako se osećate između njih.
              </p>
            </div>
          </li>

        </ol>

      </div>
    </section>

    <!-- ═══ TEME ═══════════════════════════════════════════════════════════ -->
    <section class="topics">
      <div class="container topics-inner">

        <div class="topics-text">
          <p class="eyebrow">Teme</p>
          <h2>Sa čime se najčešće radi</h2>
          <p>
            Ne postoji tema koja je "premala" ili "prevelika" za terapiju.
            Ispod su oblasti sa kojima klijenti najčešće dolaze — ali lista
            nije iscrpna. Ako vas nešto muči, o tome možemo razgovarati.
          </p>
        </div>

        <ul class="topics-list">
          <li>
            <span class="topic-dot"></span>
            <div>
              <strong>Anksioznost i brige</strong>
              <p>Stalni osećaj napetosti, strah od budućnosti, fizički simptomi stresa.</p>
            </div>
          </li>
          <li>
            <span class="topic-dot"></span>
            <div>
              <strong>Stres i sagorevanje</strong>
              <p>Preopterećenost poslom ili obavezama, osećaj da "nema kraja".</p>
            </div>
          </li>
          <li>
            <span class="topic-dot"></span>
            <div>
              <strong>Odnosi i komunikacija</strong>
              <p>Partnerski odnosi, porodična dinamika, teškoće u postavljanju granica.</p>
            </div>
          </li>
          <li>
            <span class="topic-dot"></span>
            <div>
              <strong>Samopouzdanje i identitet</strong>
              <p>Kritički unutrašnji glas, osećaj nedovoljnosti, traženje sopstvene vrednosti.</p>
            </div>
          </li>
          <li>
            <span class="topic-dot"></span>
            <div>
              <strong>Životne promene i tranzicije</strong>
              <p>Posao, selidba, gubitak, kraj veze — periodi kada "sve odjednom".</p>
            </div>
          </li>
        </ul>

      </div>
    </section>

    <!-- ═══ ONLINE I UŽIVO ════════════════════════════════════════════════ -->
    <section class="format">
      <div class="container format-inner">
        <div class="format-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <path d="M8 21h8M12 17v4"/>
          </svg>
        </div>
        <div>
          <h2>Uživo i online</h2>
          <p>
            Seanse se mogu odvijati u prostoru u Beogradu ili putem bezbedne
            video veze — na vama je šta vam više odgovara. Mnogi klijenti
            kombinuju oba formata u zavisnosti od nedelje. Online seanse nisu
            zamena za "pravi" razgovor — iskustvo pokazuje da su jednako
            efikasne za većinu tema sa kojima radimo.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══ CTA TRAKA ═════════════════════════════════════════════════════ -->
    <section class="cta-strip">
      <div class="container cta-inner">
        <h2>Gotovi ste za prvi korak?</h2>
        <a href="/kontakt" class="btn btn-primary btn-lg" data-booking-trigger>Zakažite besplatnu konsultaciju</a>
      </div>
    </section>

  </main>

  <Footer />

</BaseLayout>

<style>
  /* ── Eyebrow (shared) ─────────────────────────────────────────────────── */
  .eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    max-width: none;
  }

  /* ── Page Hero ────────────────────────────────────────────────────────── */
  .page-hero {
    padding-top: var(--space-20);
    padding-bottom: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .page-hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: var(--container-md);
  }

  .page-hero h1 {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .page-hero-sub {
    font-size: var(--text-md);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-width: 58ch;
  }

  /* ── Steps ────────────────────────────────────────────────────────────── */
  .steps {
    padding-block: var(--space-24);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-12);
  }

  .section-header h2 {
    font-size: var(--text-3xl);
    font-weight: 600;
  }

  .steps-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: var(--container-md);
    border-top: 1px solid var(--color-border);
  }

  .step {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: var(--space-8);
    padding-block: var(--space-10);
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }

  @media (max-width: 600px) {
    .step {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }

  .step-number {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 300;
    color: var(--color-border);
    line-height: 1;
    padding-top: 4px;
  }

  .step-body h3 {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-3);
  }

  .step-body p {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    max-width: 54ch;
  }

  /* ── Topics ───────────────────────────────────────────────────────────── */
  .topics {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-24);
  }

  .topics-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  @media (max-width: 767px) {
    .topics-inner {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
  }

  .topics-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: sticky;
    top: calc(68px + var(--space-8));
  }

  .topics-text h2 {
    font-size: var(--text-2xl);
    font-weight: 600;
  }

  .topics-text > p {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
  }

  .topics-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .topics-list li {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .topic-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 7px;
  }

  .topics-list strong {
    display: block;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .topics-list p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }

  /* ── Format ───────────────────────────────────────────────────────────── */
  .format {
    padding-block: var(--space-24);
    border-bottom: 1px solid var(--color-border);
  }

  .format-inner {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: var(--space-8);
    max-width: var(--container-md);
    align-items: start;
  }

  @media (max-width: 600px) {
    .format-inner {
      grid-template-columns: 1fr;
    }
  }

  .format-icon {
    width: 52px;
    height: 52px;
    background-color: var(--color-accent-light);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 4px;
  }

  .format-inner h2 {
    font-size: var(--text-2xl);
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  .format-inner p {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    max-width: 56ch;
  }

  /* ── CTA strip ────────────────────────────────────────────────────────── */
  .cta-strip {
    padding-block: var(--space-24);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-8);
  }

  .cta-inner h2 {
    font-size: clamp(var(--text-2xl), 3.5vw, var(--text-3xl));
    font-weight: 600;
    line-height: var(--leading-snug);
  }

  .btn-lg {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-sm);
  }

  @media (max-width: 767px) {
    .page-hero h1 { font-size: var(--text-2xl); }
    .page-hero-sub { font-size: var(--text-base); }
    .section-header { margin-bottom: var(--space-8); }
    .section-header h2 { font-size: var(--text-2xl); }
    .topics-text { position: static; }
    .step-body p { max-width: 100%; }
    .format-inner p { max-width: 100%; }
    .cta-inner h2 { font-size: var(--text-2xl); }
    .cta-inner .btn { width: 100%; max-width: 320px; justify-content: center; }
  }
</style>
