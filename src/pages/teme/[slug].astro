---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const articles = await getCollection('teme');
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('sr-Latn', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
}
---

<BaseLayout
  title={`${article.data.title} — Forma Uma`}
  description={article.data.description}
>

  <Nav />

  <main>

    <!-- ═══ ARTICLE HERO ══════════════════════════════════════════════════ -->
    <section class="article-hero">
      <div class="container article-hero-inner">
        <div class="article-meta-top">
          <a href="/teme" class="back-link">← Sve teme</a>
          <span class="article-tag">{article.data.tag}</span>
        </div>
        <h1>{article.data.title}</h1>
        <p class="article-desc">{article.data.description}</p>
        <time class="article-date" datetime={article.data.date.toISOString()}>
          {formatDate(article.data.date)}
        </time>
      </div>
    </section>

    <!-- ═══ ARTICLE BODY ══════════════════════════════════════════════════ -->
    <article class="article-body">
      <div class="container article-content">
        <Content />
      </div>
    </article>

    <!-- ═══ CTA TRAKA ═════════════════════════════════════════════════════ -->
    <section class="cta-strip">
      <div class="container cta-inner">
        <h2>Ovo vam zvuči poznato?</h2>
        <a href="/kontakt" class="btn btn-primary btn-lg">Zakažite besplatnu konsultaciju</a>
        <a href="/teme" class="back-articles">← Ostali tekstovi</a>
      </div>
    </section>

  </main>

  <Footer />

</BaseLayout>

<style>
  /* ── Article Hero ─────────────────────────────────────────────────────── */
  .article-hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-border);
  }

  .article-hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: var(--container-md);
  }

  .article-meta-top {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .back-link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .article-tag {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-family: var(--font-body);
    background-color: var(--color-accent-light);
    padding: 3px var(--space-3);
    border-radius: var(--radius-full);
  }

  .article-hero h1 {
    font-size: clamp(var(--text-2xl), 3.5vw, var(--text-4xl));
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: var(--leading-snug);
  }

  .article-desc {
    font-size: var(--text-md);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-width: 58ch;
  }

  .article-date {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
  }

  /* ── Article Content ──────────────────────────────────────────────────── */
  .article-body {
    padding-block: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .article-content {
    max-width: var(--container-sm);
  }

  /* Markdown prose styles */
  .article-content :global(h2) {
    font-size: var(--text-xl);
    font-weight: 500;
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    line-height: var(--leading-snug);
  }

  .article-content :global(h3) {
    font-size: var(--text-lg);
    font-weight: 500;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .article-content :global(p) {
    font-size: var(--text-base);
    line-height: var(--leading-loose);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
    max-width: 64ch;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .article-content :global(li) {
    font-size: var(--text-base);
    line-height: var(--leading-loose);
    color: var(--color-text-muted);
  }

  .article-content :global(strong) {
    font-weight: 600;
    color: var(--color-text);
  }

  .article-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: var(--space-10);
  }

  .article-content :global(em) {
    font-style: italic;
    color: var(--color-text-muted);
  }

  .article-content :global(a) {
    color: var(--color-accent);
    text-underline-offset: 3px;
  }

  /* ── CTA strip ────────────────────────────────────────────────────────── */
  .cta-strip {
    padding-block: var(--space-24);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-6);
  }

  .cta-inner h2 {
    font-size: clamp(var(--text-2xl), 3.5vw, var(--text-3xl));
    font-weight: 400;
    line-height: var(--leading-snug);
  }

  .btn-lg {
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-sm);
  }

  .back-articles {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .back-articles:hover {
    color: var(--color-accent);
  }

  @media (max-width: 767px) {
    .article-hero h1 { font-size: var(--text-xl); }
    .article-desc { font-size: var(--text-base); }
    .article-content :global(h2) { font-size: var(--text-lg); margin-top: var(--space-8); }
    .cta-inner h2 { font-size: var(--text-2xl); }
    .cta-inner .btn { width: 100%; max-width: 320px; justify-content: center; }
  }
</style>
