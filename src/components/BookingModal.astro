---
import BookingForm from './BookingForm.astro';
---

<div
  id="bookingModal"
  class="bmodal-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="bookingModalTitle"
  aria-hidden="true"
>
  <div class="bmodal-panel">

    <button
      class="bmodal-close"
      id="bookingModalClose"
      type="button"
      aria-label="Zatvori"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true" focusable="false">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <h2 id="bookingModalTitle" class="bmodal-title">Zakažite besplatnu konsultaciju</h2>

    <BookingForm formId="bookingFormModal" />

  </div>
</div>

<style>
  /* ── Overlay ─────────────────────────────────────────────────────────── */
  .bmodal-overlay {
    position: fixed;
    inset: 0;
    z-index: 500;
    background-color: rgba(28, 26, 23, 0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .bmodal-overlay:not([aria-hidden="true"]) {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Panel ───────────────────────────────────────────────────────────── */
  .bmodal-panel {
    position: relative;
    background-color: var(--color-bg);
    border-radius: var(--radius-lg);
    width: 100%;
    max-width: 520px;
    max-height: 90dvh;
    overflow-y: auto;
    padding: var(--space-10) var(--space-10) var(--space-8);
    box-shadow: var(--shadow-lg);
    transform: translateY(16px);
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .bmodal-overlay:not([aria-hidden="true"]) .bmodal-panel {
    transform: translateY(0);
  }

  /* ── Close button ─────────────────────────────────────────────────────── */
  .bmodal-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    cursor: pointer;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      color            var(--duration-fast) var(--ease-out);
  }

  .bmodal-close:hover {
    background-color: var(--color-surface);
    color: var(--color-text);
  }

  /* ── Title ───────────────────────────────────────────────────────────── */
  .bmodal-title {
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: var(--leading-snug);
    margin-bottom: var(--space-8);
    padding-right: var(--space-10);
  }

  /* ── Mobile: bottom sheet ─────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .bmodal-overlay {
      align-items: flex-end;
      padding: 0;
    }
    .bmodal-panel {
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      max-height: 92dvh;
      padding: var(--space-8) var(--space-5) var(--space-8);
    }
  }
</style>

<script>
  const overlay  = document.getElementById('bookingModal') as HTMLElement | null;
  const closeBtn = document.getElementById('bookingModalClose') as HTMLButtonElement | null;
  let lastTrigger: HTMLElement | null = null;

  // ── Open / close ──────────────────────────────────────────────────────────
  function openModal() {
    if (!overlay) return;
    overlay.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
    getFocusable()[0]?.focus();
  }

  function closeModal() {
    if (!overlay) return;
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    lastTrigger?.focus();
  }

  function getFocusable(): HTMLElement[] {
    return Array.from(
      overlay!.querySelectorAll<HTMLElement>(
        'button:not([disabled]), [href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])'
      )
    ).filter(el => !el.closest('[hidden]'));
  }

  // ── Global click: open on data-booking-trigger ────────────────────────────
  document.addEventListener('click', (e: MouseEvent) => {
    const trigger = (e.target as Element).closest<HTMLElement>('[data-booking-trigger]');
    if (!trigger) return;
    e.preventDefault();
    lastTrigger = trigger;
    openModal();
  });

  // ── Close: X button, overlay click, Escape ────────────────────────────────
  closeBtn?.addEventListener('click', closeModal);

  overlay?.addEventListener('click', (e: MouseEvent) => {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && overlay?.getAttribute('aria-hidden') !== 'true') {
      closeModal();
    }
  });

  // ── Focus trap ────────────────────────────────────────────────────────────
  overlay?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key !== 'Tab') return;
    const focusable = getFocusable();
    const first = focusable[0];
    const last  = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last?.focus(); }
    } else {
      if (document.activeElement === last)  { e.preventDefault(); first?.focus(); }
    }
  });

  // ── Form handling: modal form + any embedded .bform on the page ───────────
  document.querySelectorAll<HTMLFormElement>('.bform').forEach(form => {

    // Set today as minimum selectable date
    form.querySelectorAll<HTMLInputElement>('.bform-date-input').forEach(input => {
      input.min = new Date().toISOString().split('T')[0];
    });

    form.addEventListener('submit', (e: SubmitEvent) => {
      e.preventDefault();
      if (!form.checkValidity()) { form.reportValidity(); return; }

      /*
       * ── DOSTAVA EMAILA ────────────────────────────────────────────────────
       * Simulacija: forma se ne šalje nigde. Da biste aktivirali pravi email:
       *
       * Formspree — promenite action="" u formi na vaš URL, pa dodajte ovde:
       *   const res = await fetch(form.action, {
       *     method: 'POST', body: new FormData(form),
       *     headers: { Accept: 'application/json' }
       *   });
       *   if (!res.ok) { /* prikaz greške *‌/ return; }
       *
       * Web3Forms — dodajte <input type="hidden" name="access_key" value="…"> u formu,
       *   pa fetchujte 'https://api.web3forms.com/submit'.
       *
       * Netlify Forms — dodajte data-netlify="true" na <form> i uklonite
       *   e.preventDefault(); forma će se submitovati standardno.
       *
       * Nakon integracije: premestite prikazivanje success div-a u then()/callback.
       * ─────────────────────────────────────────────────────────────────────
       */

      // Pronađi success div koji prethodi formi u DOM-u
      const successEl = form.previousElementSibling as HTMLElement | null;
      if (successEl?.classList.contains('bform-success')) {
        form.hidden = true;
        successEl.hidden = false;
        successEl.focus();
      }
    });
  });
</script>
