<footer class="footer">
  <div class="container footer-inner">

    <div class="footer-brand">
      <p class="footer-logo">Forma Uma</p>
      <p>Psihoterapijska praksa<br>Beograd i online</p>
    </div>

    <nav class="footer-nav">
      <p class="footer-heading">Navigacija</p>
      <ul>
        <li><a href="/pristup">Pristup</a></li>
        <li><a href="/teme">Teme</a></li>
        <li><a href="/o-nama">O nama</a></li>
        <li><a href="/kontakt">Kontakt</a></li>
      </ul>
    </nav>

    <div class="footer-contact">
      <p class="footer-heading">Kontakt</p>
      <p>[email]</p>
      <p>[telefon]</p>
      <p class="footer-hours">Pon – Pet, 09:00 – 20:00</p>
    </div>

  </div>
  <div class="container footer-bottom">
    <p>© 2025 Forma Uma. Sva prava zadržana.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-12);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
  }

  @media (max-width: 767px) {
    .footer-inner { grid-template-columns: 1fr; gap: var(--space-8); }
  }

  .footer-brand p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    max-width: none;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-text) !important;
    margin-bottom: var(--space-3);
  }

  .footer-heading {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-bottom: var(--space-4);
    max-width: none;
  }

  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-nav a {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-nav a:hover { color: var(--color-accent); }

  .footer-contact p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    max-width: none;
    line-height: var(--leading-loose);
  }

  .footer-hours {
    font-size: var(--text-xs) !important;
    color: var(--color-text-subtle) !important;
    margin-top: var(--space-2);
  }

  .footer-bottom p {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    max-width: none;
  }
</style>
