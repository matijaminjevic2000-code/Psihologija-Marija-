---
interface Props {
  formId?: string;
}
const { formId = 'bform' } = Astro.props;
---

<!-- Success poruka (prikazuje se nakon slanja) -->
<div class="bform-success" hidden tabindex="-1" role="status">
  <div class="bform-success-icon" aria-hidden="true">✓</div>
  <p class="bform-success-heading">Hvala!</p>
  <p>Vaš upit je primljen. Kontaktiraćemo Vas u najkraćem mogućem roku.</p>
</div>

<!--
  DOSTAVA EMAILA — povežite vaš servis na ovo mesto:
  ─────────────────────────────────────────────────────────────────────────────
  1) Formspree: postavite action="https://formspree.io/f/VAŠE_ID"
     U skriptu (BookingModal.astro) pronađite oznaku DOSTAVA i dodajte fetch poziv.

  2) Web3Forms: action="https://api.web3forms.com/submit"
     Dodajte: <input type="hidden" name="access_key" value="VAŠ_KLJUČ" />

  3) Netlify Forms: dodajte data-netlify="true" na <form> i uklonite
     e.preventDefault() iz JS submit handlera.
  ─────────────────────────────────────────────────────────────────────────────
-->
<form id={formId} class="bform" novalidate method="POST" action="">

  <div class="bform-grid">

    <div class="bform-field">
      <label for={`${formId}-name`}>
        Ime i prezime
        <span class="bform-req" aria-label="obavezno">*</span>
      </label>
      <input
        type="text"
        id={`${formId}-name`}
        name="name"
        required
        autocomplete="name"
        placeholder="npr. Ana Petrović"
      />
    </div>

    <div class="bform-field">
      <label for={`${formId}-phone`}>
        Mobilni telefon
        <span class="bform-req" aria-label="obavezno">*</span>
      </label>
      <input
        type="tel"
        id={`${formId}-phone`}
        name="phone"
        required
        autocomplete="tel"
        placeholder="npr. 0601234567"
      />
    </div>

    <div class="bform-field">
      <label for={`${formId}-email`}>
        Email adresa
        <span class="bform-req" aria-label="obavezno">*</span>
      </label>
      <input
        type="email"
        id={`${formId}-email`}
        name="email"
        required
        autocomplete="email"
        placeholder="vas@email.com"
      />
    </div>

    <div class="bform-field bform-field--row">
      <div class="bform-field">
        <label for={`${formId}-date`}>Željeni datum</label>
        <input
          type="date"
          id={`${formId}-date`}
          name="date"
          class="bform-date-input"
        />
      </div>
      <div class="bform-field">
        <label for={`${formId}-time`}>Željeno vreme</label>
        <input
          type="time"
          id={`${formId}-time`}
          name="time"
          min="09:00"
          max="20:00"
        />
      </div>
    </div>

    <div class="bform-field">
      <label for={`${formId}-message`}>
        Poruka
        <span class="bform-optional">(opciono)</span>
      </label>
      <textarea
        id={`${formId}-message`}
        name="message"
        rows="3"
        placeholder="Kratko opišite šta vas dovodi ili postavite pitanje..."
      ></textarea>
    </div>

    <div class="bform-field bform-field--check">
      <input
        type="checkbox"
        id={`${formId}-privacy`}
        name="privacy"
        required
      />
      <label for={`${formId}-privacy`}>
        Slanjem prihvatam
        <a href="/politika-privatnosti" target="_blank" rel="noopener">politiku privatnosti</a>
        <span class="bform-req" aria-label="obavezno">*</span>
      </label>
    </div>

  </div>

  <button type="submit" class="btn btn-primary bform-submit">Pošaljite upit</button>
  <p class="bform-required-note"><span aria-hidden="true">*</span> Obavezna polja</p>

</form>

<style>
  /* ── Grid ────────────────────────────────────────────────────────────── */
  .bform-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-bottom: var(--space-6);
  }

  /* ── Field ───────────────────────────────────────────────────────────── */
  .bform-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .bform-field label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    max-width: none;
    line-height: 1.4;
  }

  .bform-req {
    color: var(--color-cta);
    margin-left: 2px;
  }

  .bform-optional {
    font-weight: 400;
    color: var(--color-text-subtle);
    font-size: var(--text-xs);
    margin-left: var(--space-1);
  }

  /* ── Inputs ──────────────────────────────────────────────────────────── */
  .bform-field input:not([type="checkbox"]),
  .bform-field textarea {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: #FFFFFF;
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.5;
    width: 100%;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      box-shadow   var(--duration-fast) var(--ease-out);
  }

  .bform-field input:focus,
  .bform-field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(47, 93, 88, 0.15);
  }

  .bform-field input:user-invalid,
  .bform-field textarea:user-invalid {
    border-color: #C0392B;
  }

  .bform-field textarea {
    resize: vertical;
    min-height: 80px;
  }

  /* ── Date + Time row ─────────────────────────────────────────────────── */
  .bform-field--row {
    flex-direction: row;
    gap: var(--space-4);
  }

  .bform-field--row > .bform-field {
    flex: 1;
  }

  @media (max-width: 420px) {
    .bform-field--row { flex-direction: column; }
  }

  /* ── Checkbox ────────────────────────────────────────────────────────── */
  .bform-field--check {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-3);
  }

  .bform-field--check input[type="checkbox"] {
    width: 18px;
    height: 18px;
    min-width: 18px;
    margin-top: 2px;
    accent-color: var(--color-accent);
    cursor: pointer;
    padding: 0;
  }

  .bform-field--check label {
    font-weight: 400;
    color: var(--color-text-muted);
    cursor: pointer;
    line-height: 1.5;
  }

  .bform-field--check label a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Submit ──────────────────────────────────────────────────────────── */
  .bform-submit {
    width: 100%;
    justify-content: center;
    margin-bottom: var(--space-2);
  }

  .bform-required-note {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    text-align: center;
    max-width: none;
  }

  /* ── Success ─────────────────────────────────────────────────────────── */
  .bform-success[hidden] { display: none; }

  .bform-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
    padding: var(--space-10) var(--space-4);
  }

  .bform-success-icon {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background-color: var(--color-accent-light);
    color: var(--color-accent);
    font-size: var(--text-xl);
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .bform-success-heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-text);
    max-width: none;
  }

  .bform-success p:last-child {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    max-width: 38ch;
  }
</style>
